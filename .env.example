# Django
DJANGO_SECRET_KEY=generate-a-50-char-random-string-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (Railway PostgreSQL)
PGDATABASE=kwallet
PGUSER=kwallet
PGPASSWORD=
PGHOST=localhost
PGPORT=5432

# Redis (Railway Redis plugin — Risk #10)
REDIS_URL=redis://localhost:6379/0

# M-Pesa (Risk #05, #07)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_B2C_INITIATOR=
MPESA_B2C_CREDENTIAL=
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback/
MPESA_B2C_RESULT_URL=https://yourdomain.com/mpesa/b2c/result/
MPESA_CALLBACK_SECRET=generate-random-secret-here
MPESA_ENVIRONMENT=sandbox
MPESA_USE_MOCK=True
MPESA_DEV_DISABLE_SSL=False

# Airtel Money Kenya
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_ENVIRONMENT=sandbox
AIRTEL_CALLBACK_SECRET=generate-random-airtel-secret-here
AIRTEL_CALLBACK_IPS=

# Email alerts (Risk #01, #12)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=alerts@kwallet.app
OPS_EMAIL=ops@kwallet.app
